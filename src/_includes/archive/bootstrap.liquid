<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="initial-scale=1, width=device-width">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="{{ '/assets/css/bootstrap-styles.css' | url }}" rel="stylesheet">
        <title>{{ title }}</title>
    </head>
    <body>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="{{ '/' | url }}">home</a>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="{{ '/about/' | url }}">about</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ '/interests/' | url }}">interests</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ '/contact/' | url }}">contact</a></li>
                </ul>

                <button class="btn btn-sm btn-outline-secondary ms-auto" onclick="toggleTheme()">toggle theme</button>
            </div>
        </nav>
        <main class="container my-5">
            {{ content }}
        </main>
        <footer class="text-center py-3">
            <div class="copyright-footer">
                <p>Copyright &copy; {{ year }} Tristan Lee</p>
            </div>
        </footer>
        <script src="{{ '/assets/js/script.js' | url }}"></script>
    </body>
</html>
