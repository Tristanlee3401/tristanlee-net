<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="initial-scale=1, width=device-width">
		<meta name="description" content="Tristan Lee - CS student, developer, pianist.">
		<meta property="og:title" content="{{ title }}">
		<meta property="og:description" content="Tristan Lee - CS student, developer, pianist.">
		<meta property="og:url" content="https://tristanlee.net{{ page.url }}">
		<meta property="og:type" content="website">
		<link rel="canonical" href="https://tristanlee.net{{ page.url }}">
		<link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
		<link rel="icon" type="image/x-icon" href="{{ '/assets/images/favicon/favicon.ico' | url }}">
		<link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/images/favicon/favicon-32x32.png' | url }}">
		<link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/images/favicon/favicon-16x16.png' | url }}">
		<link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/images/favicon/apple-touch-icon.png' | url }}">
		<link rel="manifest" href="{{ '/assets/images/favicon/site.webmanifest' | url }}">
        <script>
            if (localStorage.getItem('theme') === 'dark')
            {
                document.documentElement.classList.add('dark');
            }
        </script>
        <style type="text/css">
            .caret 
            {
                display: inline-block;
                width: 15px;
                height: 30px;
                background-color: currentColor;
                animation: blink 1s infinite;
            }
            @keyframes blink 
            { 
                50% { opacity: 0; } 
            }
            .home-thumb-full
            {
                max-width: 100%;
                height: auto;
                border: 2px solid transparent;
                transition: border-color 0.2s ease;
            }
            .home-thumb-full:hover
            {
                border-color: currentColor;
            }
			main
			{
				padding-top: calc(var(--nav-height, 0px) + 2.5rem);
			}
            main ul 
            { 
                list-style-type: disc; 
                margin-left: 1.5rem;
            }
            hr
            {
                border: 0;
                border-top: 1px solid currentColor;
                margin: 1.5rem 0;
                opacity: 1;
            }
        </style>
        <title>{{ title }}</title>
    </head>
    <body class="font-mono bg-[#F5F5F5] dark:bg-black text-black dark:text-white transition-colors duration-200">
        <nav class="border-b border-black dark:border-white fixed w-full top-0 left-0 z-50 bg-[#F5F5F5] dark:bg-black">
            <div class="container mx-auto px-6 py-4 flex flex-wrap justify-between items-center ">
				{% unless page.url == '/' %}
                <a class="text-xl font-bold hover:text-gray-500 transition duration-200 hover:-translate-y-[3px] inline-block" href="{{ '/' | url }}">
                    /home/
                </a>
				{% endunless %}
                <ul class="flex flex-wrap gap-4 sm:gap-6 text-base">
                    {% unless page.url == '/about/' %}
                        <li>
                            <a class="hover:text-gray-500 transition duration-200 hover:-translate-y-[3px] inline-block" href="{{ '/about/' | url }}">
                                abt/
                            </a>
                        </li>
                    {% endunless %}
                    {% unless page.url == '/interests/' %}
                        <li>
                            <a class="hover:text-gray-500 transition duration-200 hover:-translate-y-[3px] inline-block" href="{{ '/interests/' | url }}">
                                int/
                            </a>
                        </li>
                    {% endunless %}
                    {% unless page.url == '/projects/' %}
                        <li>
                            <a class="hover:text-gray-500 transition duration-200 hover:-translate-y-[3px] inline-block" href="{{ '/projects/' | url }}">
                                proj/
                            </a>
                        </li>
                    {% endunless %}
                    {% unless page.url == '/contact/' %}
                        <li>
                            <a class="hover:text-gray-500 transition duration-200 hover:-translate-y-[3px] inline-block" href="{{ '/contact/' | url }}">
                                ctc/
                            </a>
                        </li>
                    {% endunless %}
                </ul>
                <button id="themeToggle" class="border border-black dark:border-white px-3 py-1 text-sm hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition" onclick="toggleTheme()">
                </button>
            </div>
        </nav>
        <main class="container mx-auto px-6 pb-10">
            {{ content }}
        </main>
        <footer class="text-center py-8 text-sm text-gray-500">
			<div class="mb-2">
				<a href="https://instagram.com/mr.tristanlee/" class="hover:text-black dark:hover:text-white transition duration-200">instagram</a>
				<a href="https://linkedin.com/in/tristanlee3401/" class="hover:text-black dark:hover:text-white transition duration-200">linkedin</a>
			</div>
			<p>
				Copyright &copy; {{ year }} Tristan Lee
			</p>
        </footer>
        <script src="{{ '/assets/js/script.js' | url }}"></script>
    </body>
</html>
